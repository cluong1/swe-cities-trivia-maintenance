<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Leaderboard</title>
</head>
<body>
    <h1>Leaderboard</h1>
    <ul>
        <% players.forEach(player => { %>
            <li><strong><%= player.name %></strong>: <%= player.score %></li>
        <% }); %>
    </ul>
</body>
</html>