
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Quiz</title>
    <link rel="stylesheet" href="/styles.css">
</head>
<body>
    
    <header class="header">
        <div class="header-inner">
            <a href="/daily" class="logo">Daily Quiz</a>

            <nav class="navbar">
                <a href="/">Home</a>
                <a href="/leaderboard">Leaderboard</a>
                <a href="/daily" class="active">Daily Quiz</a>
                <a href="/practice">Practice Quiz</a>
                <a href="/account">Account</a>
            </nav>
        </div>
    </header>
    
    <% if (alreadyTaken) { %>
    <h2>You already completed today's quiz!</h2>
    <p>Your score was: <%= score %></p>
    <% } else { %>
        <div class="quiz-container">
            <div class="quiz-card">

                <div class="quiz-header">
                    <div class="quiz-title"><%= title %></div>
                </div>

                <div class="quiz-stats">
                    <div class="stat">
                        <span>Score</span>
                        <strong id="score"><%= typeof score !== "undefined" ? score : 0 %></strong>
                    </div>

                    <div class="stat">
                        <span>Timer</span>
                        <strong id="timer">0</strong>
                    </div>

                    <div class="stat">
                        <span>Question</span>
                        <strong id="questionIndex">1</strong>
                    </div>
                </div>

                <div class="question-text" id="question"></div>

                <div class="answers-grid">
                    <button class="answer-btn" id="ans1"></button>
                    <button class="answer-btn" id="ans2"></button>
                    <button class="answer-btn" id="ans3"></button>
                    <button class="answer-btn" id="ans4"></button>
                </div>

                <p id="output"></p>

                <button class="btn start-btn" id="startButton">
                    Start Quiz
                </button>

            </div>
        </div>
    
     <% } %>

     <div id="modal" style="display:none; position:fixed; top:0; left:0; width:100%; height:100%; background:rgba(0,0,0,0.5); justify-content:center; align-items:center;">
        <div style="background:white; padding:30px; border-radius:12px; text-align:center;">
            <h2>Quiz Complete!</h2>
            <p id="modal-score"></p>
            <button onclick="window.location.href='/'">Home</button>
        </div>
    </div>
    
    <script>
        const quizID = <%- quizID %>;
        const questionsJson = <%- JSON.stringify(questionsTable) %>;
        //this is how the questions are put into an array of arrays with[[Question, Answer]]
        questions=[];
        for(let i =0; i<questionsJson.length;i++){
            questions[i] = [questionsJson[i].Question,questionsJson[i].Answer];
        }
        //this is taking all the answers in the entire quiz and putting them in array.
        //if we need to we can make this more specific
        const citiesJson = <%- JSON.stringify(allAnswers) %>;
        cities =[];
        for(let i = 0 ; i < citiesJson.length;i++){
            cities[i]= citiesJson[i].Answer
        }
    </script>
    <script src="/javascript/dailyQuiz.js"></script>
</body>
</html>