<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Quiz</title>
    <link rel="stylesheet" href="/styles.css">
</head>
<body>

    <header class="header">
        <div class="header-inner">
            <a href="/" class="logo">Quiz</a>

            <nav class="navbar">
                <a href="/">Home</a>
                <a href="/leaderboard">Leaderboard</a>
                <a href="/daily">Daily Quiz</a>
                <a href="/practice">Practice Quiz</a>
                <% if (!user) { %>
                    <a class="active" href="/account">Log in</a>
                <% } else { %>
                    <a class="active" href="/account">Account</a>
                <% } %>
            </nav>
        </div>
    </header>
    
    
    <div class="quiz-container">
        <div class="quiz-card">

            <div class="quiz-header">
                <div class="quiz-title"><%= title %></div>
            </div>

            <div class="quiz-stats">
                <div class="stat">
                    <span>Score</span>
                    <strong id="score">0</strong>
                </div>

                <div class="stat">
                    <span>Timer</span>
                    <strong id="timer">0</strong>
                </div>

                <div class="stat">
                    <span>Question</span>
                    <strong id="questionIndex">1</strong>
                </div>
            </div>

            <div class="question-text" id="question">
                Press start to begin the quiz!
            </div>

            <div class="answers-grid">
                <button class="answer-btn" id="ans1"></button>
                <button class="answer-btn" id="ans2"></button>
                <button class="answer-btn" id="ans3"></button>
                <button class="answer-btn" id="ans4"></button>
            </div>

            <p id="output"></p>

            <button class="btn start-btn" id="startButton">
                Start Quiz
            </button>

        </div>

    
     
    
    <script>
        // ✅ Get data from backend
        const questionsJson = <%- JSON.stringify(questionsTable) %>;
        const citiesJson = <%- JSON.stringify(allAnswers) %>;

            // ✅ Convert to usable arrays
            let questions = [];
            let cities = [];

            for (let i = 0; i < questionsJson.length; i++) {
                questions.push([
                    questionsJson[i].Question,
                    questionsJson[i].Answer,
                ]);
            }

            for (let i = 0; i < citiesJson.length; i++) {
                cities.push(citiesJson[i].Answer);
            }

            // ✅ Debug check (optional but VERY helpful)
            console.log("Questions:", questions);
            console.log("Cities:", cities);
        </script>
    </script>
    <script src="/javascript/quiz.js"></script>
</body>
</html>